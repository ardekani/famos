# ── FamOS Environment Variables ──────────────────────────────────────────
#
# Copy this file to .env (for local dev) or set these in your Replit Secrets.
# Never commit real keys to version control.
#
# On Replit, these are set via the Secrets panel (padlock icon in the sidebar).
# Locally, copy to artifacts/famos/.env.local (VITE_ vars) and
# artifacts/api-server/.env (server vars).

# ── Supabase ──────────────────────────────────────────────────────────────
# Both the frontend and the API server read these.
# Find them in: Supabase Dashboard → Project Settings → API

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# ── OpenAI ────────────────────────────────────────────────────────────────
# Used server-side only (api-server) for email extraction.
# Model: gpt-4.1-nano (fast, cheap, structured-output capable)

OPENAI_API_KEY=sk-...

# ── Resend (optional) ─────────────────────────────────────────────────────
# Required only for POST /api/digest/send (emailing the daily digest).
# If not set, the send endpoint returns a 503 with a clear message.
# Get a key at: https://resend.com

RESEND_API_KEY=re_...

# Verified "from" address for sent digests.
# If not set, defaults to: FamOS <onboarding@resend.dev> (Resend test address)
RESEND_FROM_EMAIL=FamOS <digest@yourdomain.com>

# ── Server ────────────────────────────────────────────────────────────────
# Automatically set by Replit to 8080. Set manually for local dev.

PORT=8080
