# ─────────────────────────────────────────────────────
# FamOS — Environment Variables
# Copy this file to .env and fill in the values.
# Never commit .env to version control.
# ─────────────────────────────────────────────────────

# ── Supabase (frontend + backend) ──────────────────────
# Your Supabase project URL and anon (public) key.
# Find these in: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key

# Supabase service role key (server-side only — never expose to browser)
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ── OpenAI (server-side only) ───────────────────────────
# Used by the API server to parse emails with GPT.
# Never expose this key to the frontend.
OPENAI_API_KEY=sk-...

# ── Resend (server-side only) ───────────────────────────
# Used by the API server to send email digests.
RESEND_API_KEY=re_...

# ── App settings ────────────────────────────────────────
# The email domain your school emails come from (used for Gmail filter setup)
SCHOOL_EMAIL_DOMAIN=@yourdistirct.edu

# The forwarding inbox address users forward their emails to
FAMOS_INBOX_ADDRESS=inbox@famos.app
